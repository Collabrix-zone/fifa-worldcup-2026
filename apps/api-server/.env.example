NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://USER@127.0.0.1:5432/fifa_worldcup
APP_BASE_URL=http://localhost:5173

# Google OAuth (optional - email/password works without)
GOOGLE_CLIENT_ID=
